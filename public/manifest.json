{
  "name": "Wavify — Stream Your World",
  "short_name": "Wavify",
  "description": "A modern personal music streaming app powered by YouTube. Sync your favorite tracks, create playlists, and enjoy seamless playback.",
  "start_url": "/home",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "background_color": "#08080f",
  "theme_color": "#08080f",
  "lang": "en",
  "dir": "ltr",
  "categories": ["music", "entertainment", "multimedia"],
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Home",
      "short_name": "Home",
      "description": "Go to home",
      "url": "/home",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Search",
      "short_name": "Search",
      "description": "Search music",
      "url": "/search",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Liked Songs",
      "short_name": "Liked",
      "description": "Your liked songs",
      "url": "/liked",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Library",
      "short_name": "Library",
      "description": "Your library",
      "url": "/library",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "any" }]
    }
  ],
  "prefer_related_applications": false
}
